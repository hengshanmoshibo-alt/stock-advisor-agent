# Local stock-advisor runtime configuration. Copy to .env and fill real keys locally.

HOST=127.0.0.1
PORT=8020

QUOTE_PROVIDER=finnhub
MARKET_DATA_PROVIDER=massive
FINNHUB_API_KEY=
MASSIVE_API_KEY=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b

# Optional OpenAI-compatible external model fallback, for example DeepSeek.
API_KEY=
BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat

ENABLE_TRADE_PLAN_LLM=true
ENABLE_QUOTE_LOOKUP=true
EMBEDDING_BACKEND=hash
RERANKER_STRATEGY=none
